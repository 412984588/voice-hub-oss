{
  "name": "@voice-hub/openclaw-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw 插件壳 - 集成到 OpenClaw 系统",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier -w src",
    "pack": "bash scripts/pack.sh"
  },
  "dependencies": {
    "@voice-hub/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "openclaw": {
    "type": "voice-hub",
    "version": "0.1.0",
    "capabilities": [
      "voice.input",
      "voice.output",
      "session.manage"
    ]
  }
}
