{
  "name": "@voice-hub/provider",
  "version": "0.1.0",
  "type": "module",
  "description": "语音提供商抽象层 - 支持 Doubao、本地 Mock 等",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier -w src"
  },
  "dependencies": {
    "@voice-hub/shared-types": "workspace:*",
    "@voice-hub/shared-config": "workspace:*",
    "eventemitter3": "^5.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
