{
  "name": "@voice-hub/claude-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "Claude MCP Server - Model Context Protocol 服务器",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "bin": {
    "voice-hub-mcp": "./src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier -w src",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@voice-hub/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "mcp": {
    "id": "voice-hub",
    "name": "Voice Hub",
    "version": "0.1.0",
    "description": "Real-time voice interaction middleware for Claude Code",
    "author": "Voice Hub Team",
    "license": "MIT",
    "capabilities": {
      "resources": {},
      "tools": {
        "create_session": {
          "description": "Create a new voice session",
          "inputSchema": {
            "type": "object",
            "properties": {
              "userId": {
                "type": "string",
                "description": "Optional user identifier"
              }
            }
          }
        },
        "destroy_session": {
          "description": "Destroy a voice session",
          "inputSchema": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string",
                "description": "Session ID to destroy"
              },
              "required": [
                "sessionId"
              ]
            }
          }
        },
        "start_listening": {
          "description": "Start listening for voice input",
          "inputSchema": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string",
                "description": "Session ID"
              },
              "required": [
                "sessionId"
              ]
            }
          }
        },
        "stop_listening": {
          "description": "Stop listening for voice input",
          "inputSchema": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string",
                "description": "Session ID"
              },
              "required": [
                "sessionId"
              ]
            }
          }
        },
        "get_session_status": {
          "description": "Get current session status",
          "inputSchema": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string",
                "description": "Session ID"
              },
              "required": [
                "sessionId"
              ]
            }
          }
        }
      }
    }
  }
}
