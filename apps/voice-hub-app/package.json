{
  "name": "@voice-hub/app",
  "version": "0.1.0",
  "type": "module",
  "description": "Voice Hub 主应用 - Discord + OpenClaw + Claude Code 实时语音中间层",
  "main": "./src/index.js",
  "bin": {
    "voice-hub": "./src/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier -w src",
    "start": "node dist/cli.js",
    "dev": "tsx watch src/cli.ts"
  },
  "dependencies": {
    "@voice-hub/shared-types": "workspace:*",
    "@voice-hub/shared-config": "workspace:*",
    "@voice-hub/provider": "workspace:*",
    "@voice-hub/memory-bank": "workspace:*",
    "@voice-hub/backend-dispatcher": "workspace:*",
    "@voice-hub/core-runtime": "workspace:*",
    "discord.js": "^14.17.3",
    "@discordjs/voice": "^0.19.0",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
